{
  "enabledMcpjsonServers": ["puppeteer"],
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(npx jest *)",
      "Bash(npx prisma *)",
      "Bash(powershell *)"
    ],
    "additionalDirectories": [
      "d:\\ClaudeWorkSpace\\my_project\\sports-injury-platform"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/git-worktree-setup.ps1\"",
            "async": false
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session-end.ps1\"",
            "async": false
          }
        ]
      }
    ]
  }
}
